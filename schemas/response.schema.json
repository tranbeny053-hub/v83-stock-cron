{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ultimate-crypto-probability-engine.local/schemas/response.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "symbol",
    "normalized_symbol",
    "asset_class",
    "analysis_mode",
    "timeframes",
    "as_of_utc",
    "provider_state",
    "data_quality",
    "market_features",
    "liquidity_state",
    "execution_realism",
    "quant_compute_state",
    "epistemic_sufficiency_state",
    "probability_state",
    "horizon_timeout_state",
    "risk_arbiter_state",
    "tail_risk_state",
    "calibration_state",
    "macro_context",
    "micro_news_context",
    "news_addon_state",
    "news_evidence",
    "news_materiality_state",
    "event_horizon_state",
    "narrative_state",
    "novelty_surprise_state",
    "source_confidence_state",
    "information_state",
    "catalyst_state",
    "score_stack",
    "trend_summary",
    "decision_brief",
    "frontend_display",
    "detail_view",
    "gate_result",
    "debug",
    "analysis_hash"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "run_id": { "type": "string" },
    "symbol": { "type": "string" },
    "normalized_symbol": { "type": "string" },
    "asset_class": { "enum": ["CRYPTO_SPOT", "CRYPTO_PERP"] },
    "analysis_mode": { "enum": ["METRICS_ONLY", "NEWS_ADDON"] },
    "timeframes": { "type": "object" },
    "as_of_utc": { "type": "string", "format": "date-time" },
    "provider_state": { "type": "object" },
    "data_quality": { "type": "object" },
    "market_features": { "type": "object" },
    "liquidity_state": { "type": "object" },
    "execution_realism": { "type": "object" },
    "quant_compute_state": { "type": "object" },
    "epistemic_sufficiency_state": { "type": "object" },
    "probability_state": { "$ref": "quant.schema.json#/properties/probability_state" },
    "horizon_timeout_state": { "type": "object" },
    "risk_arbiter_state": { "type": "object" },
    "tail_risk_state": { "type": "object" },
    "calibration_state": { "type": "object" },
    "macro_context": { "type": "object" },
    "micro_news_context": { "type": "object" },
    "news_addon_state": { "type": "object" },
    "news_evidence": { "type": "object" },
    "news_materiality_state": { "type": "object" },
    "event_horizon_state": { "type": "object" },
    "narrative_state": { "type": "object" },
    "novelty_surprise_state": { "type": "object" },
    "source_confidence_state": { "type": "object" },
    "information_state": { "type": "object" },
    "catalyst_state": { "type": "object" },
    "score_stack": { "type": "object" },
    "trend_summary": { "type": "object" },
    "decision_brief": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action",
        "symbol",
        "normalized_symbol",
        "timeframe_label",
        "horizon_label",
        "horizon_bars",
        "probability_type",
        "model_readiness",
        "calibration_status",
        "reliability_status",
        "profitability_claim",
        "state_summary",
        "key_reasons",
        "hard_blockers",
        "watchlist_triggers",
        "invalidation_conditions",
        "volatility_reference",
        "risk_note",
        "disclaimer"
      ],
      "properties": {
        "action": { "enum": ["NO_TRADE", "WATCHLIST", "SPOT_WATCH"] },
        "symbol": { "type": "string" },
        "normalized_symbol": { "type": "string" },
        "timeframe_label": { "type": "string" },
        "horizon_label": { "type": "string" },
        "horizon_bars": { "type": "integer" },
        "probability_type": { "const": "UNCALIBRATED_HEURISTIC_6BAR_OUTCOME" },
        "model_readiness": { "type": "string" },
        "calibration_status": { "type": "string" },
        "reliability_status": { "type": "string" },
        "profitability_claim": { "const": false },
        "state_summary": { "type": "string" },
        "key_reasons": { "type": "array", "items": { "type": "string" } },
        "hard_blockers": { "type": "array", "items": { "type": "string" } },
        "watchlist_triggers": { "type": "array", "items": { "type": "string" } },
        "invalidation_conditions": { "type": "array", "items": { "type": "string" } },
        "volatility_reference": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "realized_vol", "note"],
          "properties": {
            "status": { "type": "string" },
            "realized_vol": { "type": ["number", "null"] },
            "note": { "type": "string" }
          }
        },
        "risk_note": { "type": "string" },
        "disclaimer": { "type": "string" }
      }
    },
    "decision_synthesis": { "$ref": "#/$defs/decisionSynthesis" },
    "frontend_display": { "type": "object" },
    "detail_view": { "$ref": "detail_view.schema.json" },
    "gate_result": { "type": "object" },
    "debug": { "type": "object" },
    "analysis_hash": { "type": "string" }
  },
  "$defs": {
    "decisionSynthesis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "decision_synthesis",
        "probability_interpretation",
        "timeframe_role",
        "action_permission",
        "actionability_stack",
        "model_quality_summary",
        "what_would_change_decision",
        "advisor_explanations",
        "trade_plan_skeleton",
        "future_quant_v2_hooks"
      ],
      "properties": {
        "schema_version": { "const": "1.0" },
        "decision_synthesis": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "label",
            "decision_strength",
            "plain_english",
            "source_disposition",
            "source_gate_action",
            "candidate_is_not_entry_permission"
          ],
          "properties": {
            "label": {
              "enum": [
                "AVOID",
                "NO_TRADE",
                "WAIT",
                "WATCH",
                "LONG_CANDIDATE",
                "SHORT_CANDIDATE"
              ]
            },
            "decision_strength": { "enum": ["LOW", "MODERATE", "HIGH"] },
            "plain_english": { "type": "string" },
            "source_disposition": { "type": "string" },
            "source_gate_action": { "type": "string" },
            "candidate_is_not_entry_permission": { "const": true }
          }
        },
        "probability_interpretation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "p_up",
            "p_down",
            "p_timeout",
            "directional_edge",
            "resolution_probability",
            "directional_balance",
            "interpretation_label",
            "plain_english",
            "reliability_warning",
            "informational_only"
          ],
          "properties": {
            "p_up": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
            "p_down": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
            "p_timeout": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
            "directional_edge": { "type": ["number", "null"], "minimum": -1, "maximum": 1 },
            "resolution_probability": {
              "type": ["number", "null"],
              "minimum": 0,
              "maximum": 1
            },
            "directional_balance": {
              "type": ["number", "null"],
              "minimum": 0,
              "maximum": 1
            },
            "interpretation_label": {
              "enum": ["UP_LEAN", "DOWN_LEAN", "BALANCED", "UNAVAILABLE"]
            },
            "plain_english": { "type": "string" },
            "reliability_warning": { "type": "string" },
            "informational_only": { "type": "boolean" }
          }
        },
        "timeframe_role": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "timeframe",
            "role",
            "tactical",
            "raw_probability_hidden_by_default",
            "plain_english"
          ],
          "properties": {
            "timeframe": { "type": "string" },
            "role": {
              "enum": [
                "TACTICAL_TIMING",
                "TACTICAL_SWING_BRIDGE",
                "SETUP_QUALITY",
                "SWING_CONTEXT",
                "REGIME_CONTEXT",
                "MACRO_BACKDROP",
                "UNSPECIFIED_CONTEXT"
              ]
            },
            "tactical": { "type": "boolean" },
            "raw_probability_hidden_by_default": { "type": "boolean" },
            "plain_english": { "type": "string" }
          }
        },
        "action_permission": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "can_plan_trade",
            "can_enter_now",
            "can_chase",
            "observe_only",
            "plain_english"
          ],
          "properties": {
            "can_plan_trade": { "type": "boolean" },
            "can_enter_now": { "const": false },
            "can_chase": { "const": false },
            "observe_only": { "type": "boolean" },
            "plain_english": { "type": "string" }
          }
        },
        "actionability_stack": {
          "type": "array",
          "minItems": 12,
          "maxItems": 12,
          "items": { "$ref": "#/$defs/actionabilityCheck" }
        },
        "model_quality_summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "calibration_status",
            "reliability_status",
            "sample_count",
            "sample_gate",
            "brier_score",
            "log_loss",
            "top_label_hit_rate",
            "reliability_available",
            "not_win_rate",
            "warning"
          ],
          "properties": {
            "calibration_status": { "type": "string" },
            "reliability_status": { "type": "string" },
            "sample_count": { "type": ["integer", "null"], "minimum": 0 },
            "sample_gate": { "type": ["string", "null"] },
            "brier_score": { "type": ["number", "null"] },
            "log_loss": { "type": ["number", "null"] },
            "top_label_hit_rate": { "type": ["number", "null"] },
            "reliability_available": { "type": "boolean" },
            "not_win_rate": { "const": true },
            "warning": { "type": "string" }
          }
        },
        "what_would_change_decision": {
          "type": "array",
          "items": { "$ref": "#/$defs/decisionCondition" }
        },
        "advisor_explanations": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "why_this_decision",
            "why_not_enter_now",
            "why_probability_is_muted",
            "why_timeframe_matters",
            "why_reliability_is_insufficient"
          ],
          "properties": {
            "why_this_decision": { "type": "string" },
            "why_not_enter_now": { "type": "string" },
            "why_probability_is_muted": { "type": "string" },
            "why_timeframe_matters": { "type": "string" },
            "why_reliability_is_insufficient": { "type": "string" }
          }
        },
        "trade_plan_skeleton": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "can_plan_trade",
            "can_enter_now",
            "can_chase",
            "preferred_entry_zone",
            "acceptable_entry_zone",
            "chase_zone",
            "breakout_trigger",
            "pullback_trigger",
            "stop_invalidation",
            "take_profit_plan",
            "risk_reward_summary",
            "disabled_reason"
          ],
          "properties": {
            "status": { "const": "STRUCTURAL_ONLY_D1_1" },
            "can_plan_trade": { "type": "boolean" },
            "can_enter_now": { "const": false },
            "can_chase": { "const": false },
            "preferred_entry_zone": { "type": "null" },
            "acceptable_entry_zone": { "type": "null" },
            "chase_zone": { "type": "null" },
            "breakout_trigger": { "type": "null" },
            "pullback_trigger": { "type": "null" },
            "stop_invalidation": { "type": "null" },
            "take_profit_plan": { "type": "null" },
            "risk_reward_summary": { "type": "null" },
            "disabled_reason": { "type": "string", "minLength": 1 }
          }
        },
        "future_quant_v2_hooks": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "influence_mode",
            "decision_influence_frac",
            "plain_english"
          ],
          "properties": {
            "status": { "const": "PLACEHOLDER" },
            "influence_mode": { "const": "SHADOW_ONLY" },
            "decision_influence_frac": { "const": 0.0 },
            "plain_english": { "type": "string" }
          }
        }
      }
    },
    "actionabilityCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "status", "label", "plain_english", "evidence_refs", "priority"],
      "properties": {
        "key": { "type": "string" },
        "status": { "enum": ["PASS", "WARN", "BLOCK", "INFO", "UNKNOWN"] },
        "label": { "type": "string" },
        "plain_english": { "type": "string" },
        "evidence_refs": { "type": "array", "items": { "type": "string" } },
        "priority": { "type": "integer", "minimum": 1, "maximum": 12 }
      }
    },
    "decisionCondition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "currently_relevant",
        "plain_english",
        "evidence_refs",
        "informational_only"
      ],
      "properties": {
        "key": { "type": "string" },
        "currently_relevant": { "type": "boolean" },
        "plain_english": { "type": "string" },
        "evidence_refs": { "type": "array", "items": { "type": "string" } },
        "informational_only": { "const": true }
      }
    }
  }
}
