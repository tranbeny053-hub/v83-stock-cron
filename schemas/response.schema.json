{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ultimate-crypto-probability-engine.local/schemas/response.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "symbol",
    "normalized_symbol",
    "asset_class",
    "analysis_mode",
    "timeframes",
    "as_of_utc",
    "provider_state",
    "data_quality",
    "market_features",
    "liquidity_state",
    "execution_realism",
    "quant_compute_state",
    "epistemic_sufficiency_state",
    "probability_state",
    "horizon_timeout_state",
    "risk_arbiter_state",
    "tail_risk_state",
    "calibration_state",
    "macro_context",
    "micro_news_context",
    "news_addon_state",
    "news_evidence",
    "news_materiality_state",
    "event_horizon_state",
    "narrative_state",
    "novelty_surprise_state",
    "source_confidence_state",
    "information_state",
    "catalyst_state",
    "score_stack",
    "trend_summary",
    "decision_brief",
    "frontend_display",
    "detail_view",
    "gate_result",
    "debug",
    "analysis_hash"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "run_id": { "type": "string" },
    "symbol": { "type": "string" },
    "normalized_symbol": { "type": "string" },
    "asset_class": { "enum": ["CRYPTO_SPOT", "CRYPTO_PERP"] },
    "analysis_mode": { "enum": ["METRICS_ONLY", "NEWS_ADDON"] },
    "timeframes": { "type": "object" },
    "as_of_utc": { "type": "string", "format": "date-time" },
    "provider_state": { "type": "object" },
    "data_quality": { "type": "object" },
    "market_features": { "type": "object" },
    "liquidity_state": { "type": "object" },
    "execution_realism": { "type": "object" },
    "quant_compute_state": { "type": "object" },
    "epistemic_sufficiency_state": { "type": "object" },
    "probability_state": { "$ref": "quant.schema.json#/properties/probability_state" },
    "horizon_timeout_state": { "type": "object" },
    "risk_arbiter_state": { "type": "object" },
    "tail_risk_state": { "type": "object" },
    "calibration_state": { "type": "object" },
    "macro_context": { "type": "object" },
    "micro_news_context": { "type": "object" },
    "news_addon_state": { "type": "object" },
    "news_evidence": { "type": "object" },
    "news_materiality_state": { "type": "object" },
    "event_horizon_state": { "type": "object" },
    "narrative_state": { "type": "object" },
    "novelty_surprise_state": { "type": "object" },
    "source_confidence_state": { "type": "object" },
    "information_state": { "type": "object" },
    "catalyst_state": { "type": "object" },
    "score_stack": { "type": "object" },
    "trend_summary": { "type": "object" },
    "decision_brief": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action",
        "symbol",
        "normalized_symbol",
        "timeframe_label",
        "horizon_label",
        "horizon_bars",
        "probability_type",
        "model_readiness",
        "calibration_status",
        "reliability_status",
        "profitability_claim",
        "state_summary",
        "key_reasons",
        "hard_blockers",
        "watchlist_triggers",
        "invalidation_conditions",
        "volatility_reference",
        "risk_note",
        "disclaimer"
      ],
      "properties": {
        "action": { "enum": ["NO_TRADE", "WATCHLIST", "SPOT_WATCH"] },
        "symbol": { "type": "string" },
        "normalized_symbol": { "type": "string" },
        "timeframe_label": { "type": "string" },
        "horizon_label": { "type": "string" },
        "horizon_bars": { "type": "integer" },
        "probability_type": { "const": "UNCALIBRATED_HEURISTIC_6BAR_OUTCOME" },
        "model_readiness": { "type": "string" },
        "calibration_status": { "type": "string" },
        "reliability_status": { "type": "string" },
        "profitability_claim": { "const": false },
        "state_summary": { "type": "string" },
        "key_reasons": { "type": "array", "items": { "type": "string" } },
        "hard_blockers": { "type": "array", "items": { "type": "string" } },
        "watchlist_triggers": { "type": "array", "items": { "type": "string" } },
        "invalidation_conditions": { "type": "array", "items": { "type": "string" } },
        "volatility_reference": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "realized_vol", "note"],
          "properties": {
            "status": { "type": "string" },
            "realized_vol": { "type": ["number", "null"] },
            "note": { "type": "string" }
          }
        },
        "risk_note": { "type": "string" },
        "disclaimer": { "type": "string" }
      }
    },
    "frontend_display": { "type": "object" },
    "detail_view": { "$ref": "detail_view.schema.json" },
    "gate_result": { "type": "object" },
    "debug": { "type": "object" },
    "analysis_hash": { "type": "string" }
  }
}
