{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ultimate-crypto-probability-engine.local/schemas/feature_snapshot.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "prediction_id",
    "run_id",
    "symbol",
    "normalized_symbol",
    "timeframe",
    "prediction_as_of_utc",
    "reference_close_utc",
    "quant_v2_schema_version",
    "feature_methodology_version",
    "influence_mode",
    "no_lookahead_assertion",
    "block_status",
    "feature_count",
    "degraded_count",
    "provider_signature",
    "snapshot_payload",
    "snapshot_hash"
  ],
  "properties": {
    "prediction_id": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "symbol": { "type": "string", "minLength": 1 },
    "normalized_symbol": { "type": "string", "minLength": 1 },
    "timeframe": { "type": "string", "minLength": 1 },
    "prediction_as_of_utc": {
      "type": "string",
      "format": "date-time",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}T.+(?:Z|[+-]\\d{2}:\\d{2})$"
    },
    "reference_close_utc": {
      "type": "string",
      "format": "date-time",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}T.+(?:Z|[+-]\\d{2}:\\d{2})$"
    },
    "quant_v2_schema_version": { "const": "quant_v2.0" },
    "feature_methodology_version": { "const": "quant-v2-shadow-v0" },
    "influence_mode": { "const": "SHADOW_ONLY" },
    "no_lookahead_assertion": { "type": "boolean" },
    "block_status": { "enum": ["ACTIVE", "DEGRADED", "DISABLED"] },
    "feature_count": { "enum": [0, 4] },
    "degraded_count": { "type": "integer", "minimum": 0, "maximum": 4 },
    "provider_signature": { "type": "string", "minLength": 1 },
    "snapshot_payload": { "$ref": "#/$defs/snapshotPayload" },
    "snapshot_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "allOf": [
    {
      "if": { "properties": { "block_status": { "const": "DISABLED" } } },
      "then": {
        "properties": {
          "feature_count": { "const": 0 },
          "degraded_count": { "const": 0 }
        }
      },
      "else": {
        "properties": { "feature_count": { "const": 4 } }
      }
    }
  ],
  "$defs": {
    "dataQuality": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "upstream_status",
        "provider_state_status",
        "snapshot_source_status",
        "timestamp_evidence_complete"
      ],
      "properties": {
        "upstream_status": { "type": ["string", "null"] },
        "provider_state_status": { "type": ["string", "null"] },
        "snapshot_source_status": { "type": ["string", "null"] },
        "timestamp_evidence_complete": { "type": "boolean" }
      }
    },
    "feature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "feature_name",
        "feature_id",
        "family",
        "timeframe",
        "symbol",
        "source_provider",
        "source_priority",
        "lookback",
        "candle_count",
        "computed_at",
        "input_start_time",
        "input_end_time",
        "input_staleness_seconds",
        "status",
        "reason_if_invalid",
        "raw_value",
        "normalized_value",
        "bucket",
        "direction_hint",
        "confidence_hint",
        "risk_hint",
        "influence_mode",
        "methodology_version",
        "data_quality",
        "no_lookahead_assertion"
      ],
      "properties": {
        "feature_name": { "type": "string", "minLength": 1 },
        "feature_id": { "type": "string", "minLength": 1 },
        "family": { "enum": ["VOLATILITY", "TREND", "VOLUME", "REGIME"] },
        "timeframe": { "type": "string", "minLength": 1 },
        "symbol": { "type": "string", "minLength": 1 },
        "source_provider": { "type": ["string", "null"] },
        "source_priority": {
          "oneOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "null" }
          ]
        },
        "lookback": {
          "oneOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "null" }
          ]
        },
        "candle_count": { "type": "integer", "minimum": 0 },
        "computed_at": {
          "type": ["string", "null"],
          "format": "date-time",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}T.+(?:Z|[+-]\\d{2}:\\d{2})$"
        },
        "input_start_time": {
          "type": ["string", "null"],
          "format": "date-time",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}T.+(?:Z|[+-]\\d{2}:\\d{2})$"
        },
        "input_end_time": {
          "type": ["string", "null"],
          "format": "date-time",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}T.+(?:Z|[+-]\\d{2}:\\d{2})$"
        },
        "input_staleness_seconds": { "type": ["number", "null"], "minimum": 0 },
        "status": {
          "enum": [
            "VALID",
            "INSUFFICIENT_HISTORY",
            "STALE_INPUT",
            "PROVIDER_UNAVAILABLE",
            "COMPUTE_ERROR",
            "NOT_APPLICABLE",
            "DEGRADED"
          ]
        },
        "reason_if_invalid": { "type": ["string", "null"] },
        "raw_value": { "type": ["number", "string", "null"] },
        "normalized_value": { "type": "null" },
        "bucket": { "type": "null" },
        "direction_hint": {
          "oneOf": [
            { "enum": ["UP", "DOWN", "SIDEWAYS"] },
            { "type": "null" }
          ]
        },
        "confidence_hint": { "type": "null" },
        "risk_hint": { "type": "null" },
        "influence_mode": { "const": "SHADOW_ONLY" },
        "methodology_version": { "const": "quant-v2-shadow-v0" },
        "data_quality": { "$ref": "#/$defs/dataQuality" },
        "no_lookahead_assertion": { "type": "boolean" }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "VALID" } } },
          "then": { "properties": { "reason_if_invalid": { "type": "null" } } },
          "else": {
            "properties": {
              "reason_if_invalid": { "type": "string", "minLength": 1 }
            }
          }
        }
      ]
    },
    "snapshotPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "status",
        "influence_mode",
        "feature_methodology_version",
        "computed_at_utc",
        "symbol",
        "normalized_symbol",
        "timeframe",
        "reference_close_utc",
        "input_staleness_seconds",
        "no_lookahead_assertion",
        "feature_count",
        "degraded_count",
        "not_trade_command",
        "not_financial_advice",
        "features"
      ],
      "properties": {
        "schema_version": { "const": "quant_v2.0" },
        "status": { "enum": ["ACTIVE", "DEGRADED", "DISABLED"] },
        "influence_mode": { "const": "SHADOW_ONLY" },
        "feature_methodology_version": { "const": "quant-v2-shadow-v0" },
        "computed_at_utc": {
          "type": "string",
          "format": "date-time",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}T.+(?:Z|[+-]\\d{2}:\\d{2})$"
        },
        "symbol": { "type": "string", "minLength": 1 },
        "normalized_symbol": { "type": "string", "minLength": 1 },
        "timeframe": { "type": "string", "minLength": 1 },
        "reference_close_utc": {
          "type": "string",
          "format": "date-time",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}T.+(?:Z|[+-]\\d{2}:\\d{2})$"
        },
        "input_staleness_seconds": { "type": ["number", "null"], "minimum": 0 },
        "no_lookahead_assertion": { "type": "boolean" },
        "feature_count": { "enum": [0, 4] },
        "degraded_count": { "type": "integer", "minimum": 0, "maximum": 4 },
        "not_trade_command": { "const": true },
        "not_financial_advice": { "const": true },
        "features": { "type": "array", "items": { "$ref": "#/$defs/feature" } }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "DISABLED" } } },
          "then": {
            "properties": {
              "feature_count": { "const": 0 },
              "degraded_count": { "const": 0 },
              "features": { "maxItems": 0 }
            }
          },
          "else": {
            "properties": {
              "feature_count": { "const": 4 },
              "features": { "minItems": 4, "maxItems": 4 }
            }
          }
        },
        {
          "if": { "properties": { "status": { "const": "ACTIVE" } } },
          "then": {
            "properties": {
              "degraded_count": { "const": 0 },
              "no_lookahead_assertion": { "const": true }
            }
          }
        },
        {
          "if": { "properties": { "status": { "const": "DEGRADED" } } },
          "then": { "properties": { "degraded_count": { "minimum": 1 } } }
        }
      ]
    }
  }
}
