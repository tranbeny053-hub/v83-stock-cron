{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ultimate-crypto-probability-engine.local/schemas/quant.schema.json",
  "type": "object",
  "properties": {
    "probability_state": {
      "type": "object",
      "required": ["schema_version", "horizons", "calibration_status"],
      "properties": {
        "schema_version": { "type": "string" },
        "calibration_status": { "type": "string" },
        "null_reason": { "type": ["string", "null"] },
        "horizons": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["p_up_frac", "p_down_frac", "p_timeout_frac", "confidence_frac", "status"],
            "properties": {
              "p_up_frac": { "type": "number", "minimum": 0, "maximum": 1 },
              "p_down_frac": { "type": "number", "minimum": 0, "maximum": 1 },
              "p_timeout_frac": { "type": "number", "minimum": 0, "maximum": 1 },
              "p_up_user_norm_frac": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
              "p_down_user_norm_frac": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
              "confidence_frac": { "type": "number", "minimum": 0, "maximum": 1 },
              "news_confidence_adj_frac": { "type": "number", "minimum": 0, "maximum": 1 },
              "status": { "type": "string" },
              "null_reason": { "type": ["string", "null"] }
            }
          }
        }
      }
    }
  }
}
